# All values default to the live demo backend, so the app runs with zero config.
# Override here only if you point at a different openct deployment.
VITE_API_BASE_URL=https://openct-api.onrender.com
VITE_AUTH_BASE_URL=https://openct-auth.onrender.com
VITE_PROJECT_KEY=openct-dev

# The OAuth client secret is NOT a browser/Vite var — it must never reach the bundle. It is held
# server-side by the token BFF (netlify/functions/token.mjs) and set as a *runtime* env var in the
# Netlify dashboard. For local `netlify dev`, put it in a gitignored .env (placeholders shown):
#   CLIENT_ID=lumora-store
#   CLIENT_SECRET=replace-with-the-rotated-secret
